<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vanvaas</title>

    <!-- CSS LINKS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <style>
      /* PASTE YOUR ENTIRE STYLE FROM HOME.EJS HERE */
      :root {
        --bg-main: #0f1f1a;
        --bg-secondary: #0a1612;
        --panel: rgba(27, 47, 40, 0.95);
        --card-bg: #1b2f28;
        --accent: #3a7d44;
        --accent-light: #52b788;
        --accent-orange: #f4a261;
        --text: #e9f5ee;
        --muted: #a8c5b3;
        --border: #2d4a3e;
        --input-bg: #152520;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Poppins", sans-serif;
        background: linear-gradient(
          135deg,
          var(--bg-main),
          var(--bg-secondary)
        );
        min-height: 100vh;
        color: var(--text);
      }

      /* Atmosphere Effect */
      body::before {
        content: "";
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background:
          radial-gradient(
            ellipse at 20% 30%,
            rgba(58, 125, 68, 0.1) 0%,
            transparent 50%
          ),
          radial-gradient(
            ellipse at 80% 70%,
            rgba(244, 162, 97, 0.05) 0%,
            transparent 50%
          );
        pointer-events: none;
        z-index: 0;
      }

      /* Navbar */
      .navbar-custom {
        background: var(--panel);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--border);
        padding: 18px 0;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        position: sticky;
        top: 0;
        z-index: 1000;
      }

      .navbar-brand {
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--text) !important;
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        transition: 0.3s ease;
      }

      .navbar-brand:hover {
        color: var(--accent-light) !important;
      }

      .nav-links {
        display: flex;
        gap: 10px;
        align-items: center;
      }

      .nav-link-custom {
        color: var(--muted);
        text-decoration: none;
        padding: 10px 20px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 500;
        font-size: 1rem;
        transition: 0.3s ease;
      }

      .nav-link-custom:hover {
        color: var(--text);
        background: rgba(58, 125, 68, 0.2);
      }

      .btn-auth {
        background: transparent;
        border: 1px solid var(--accent-light);
        color: var(--accent-light);
        padding: 8px 20px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }

      .btn-auth:hover {
        background: var(--accent-light);
        color: var(--bg-main);
      }

      .user-welcome {
        color: var(--accent-light);
        font-weight: 600;
        padding: 10px 15px;
        background: rgba(58, 125, 68, 0.2);
        border-radius: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .btn-logout {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--muted);
      }

      .btn-logout:hover {
        background: rgba(244, 162, 97, 0.2);
        border-color: var(--accent-orange);
        color: var(--accent-orange);
      }

      /* Mobile Menu */
      .mobile-menu-toggle {
        display: none;
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text);
        padding: 8px 12px;
        border-radius: 8px;
        font-size: 1.2rem;
        cursor: pointer;
      }

      /* Hero Section */
      .hero-section {
        padding: 100px 20px;
        position: relative;
        z-index: 1;
      }

      .hero-container {
        max-width: 1400px;
        margin: auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
      }

      .hero-content h1 {
        font-size: 3.5rem;
        font-weight: 700;
        margin-bottom: 25px;
        line-height: 1.2;
        color: var(--text);
        text-shadow: 0 2px 20px rgba(58, 125, 68, 0.3);
      }

      .hero-content p {
        font-size: 1.2rem;
        color: var(--muted);
        margin-bottom: 40px;
        line-height: 1.7;
      }

      .hero-buttons {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
      }

      .btn-hero {
        padding: 16px 40px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1.1rem;
        text-decoration: none;
        transition: 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        border: none;
        cursor: pointer;
      }

      .btn-hero-primary {
        background: linear-gradient(135deg, var(--accent-orange), #e8915b);
        color: var(--bg-main);
      }

      .btn-hero-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 30px rgba(244, 162, 97, 0.5);
        color: var(--bg-main);
      }

      .btn-hero-secondary {
        background: transparent;
        border: 2px solid var(--accent-light);
        color: var(--accent-light);
      }

      .btn-hero-secondary:hover {
        background: var(--accent-light);
        color: var(--bg-main);
        transform: translateY(-3px);
      }

      /* Hero Image Slider */
      .hero-slider {
        position: relative;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
        border: 2px solid var(--border);
      }

      .hero-slider img {
        width: 100%;
        height: 500px;
        object-fit: cover;
        display: none;
      }

      .hero-slider img.active {
        display: block;
      }

      .slider-controls {
        position: absolute;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 10px;
      }

      .slider-dot {
        width: 40px;
        height: 4px;
        background: rgba(255, 255, 255, 0.5);
        border-radius: 2px;
        cursor: pointer;
        transition: 0.3s ease;
      }

      .slider-dot.active {
        background: var(--accent-orange);
        width: 60px;
      }

      .slider-arrow {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(0, 0, 0, 0.5);
        color: white;
        border: none;
        padding: 15px 20px;
        font-size: 1.5rem;
        cursor: pointer;
        border-radius: 10px;
        transition: 0.3s ease;
      }

      .slider-arrow:hover {
        background: rgba(244, 162, 97, 0.8);
      }

      .slider-arrow.left {
        left: 20px;
      }

      .slider-arrow.right {
        right: 20px;
      }

      /* Features Section */
      .features-section {
        padding: 80px 20px;
        background: rgba(27, 47, 40, 0.3);
        position: relative;
        z-index: 1;
      }

      .features-container {
        max-width: 1400px;
        margin: auto;
      }

      .features-section h2 {
        text-align: center;
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 60px;
        color: var(--text);
      }

      .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
      }

      .feature-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 40px 30px;
        text-align: center;
        transition: 0.3s ease;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
      }

      .feature-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 35px rgba(58, 125, 68, 0.3);
        border-color: var(--accent);
      }

      .feature-icon {
        font-size: 3.5rem;
        color: var(--accent-light);
        margin-bottom: 20px;
      }

      .feature-card h3 {
        font-size: 1.4rem;
        font-weight: 600;
        margin-bottom: 15px;
        color: var(--text);
      }

      .feature-card p {
        color: var(--muted);
        line-height: 1.6;
        font-size: 1rem;
      }

      /* CTA Section */
      .cta-section {
        padding: 100px 20px;
        text-align: center;
        position: relative;
        z-index: 1;
      }

      .cta-section h2 {
        font-size: 2.8rem;
        font-weight: 700;
        margin-bottom: 20px;
        color: var(--text);
      }

      .cta-section p {
        font-size: 1.2rem;
        color: var(--muted);
        margin-bottom: 40px;
        max-width: 800px;
        margin-left: auto;
        margin-right: auto;
      }

      /* Footer */
      .footer {
        background: var(--panel);
        border-top: 1px solid var(--border);
        padding: 60px 20px 30px;
        position: relative;
        z-index: 1;
      }

      .footer-container {
        max-width: 1400px;
        margin: auto;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: 60px;
        margin-bottom: 40px;
      }

      .footer-brand h3 {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 15px;
        color: var(--text);
      }

      .footer-brand p {
        color: var(--muted);
        line-height: 1.7;
        margin-bottom: 0;
      }

      .footer-section h4 {
        font-size: 1.2rem;
        font-weight: 600;
        margin-bottom: 20px;
        color: var(--text);
      }

      .footer-links {
        list-style: none;
        padding: 0;
      }

      .footer-links li {
        margin-bottom: 12px;
      }

      .footer-links a {
        color: var(--muted);
        text-decoration: none;
        transition: 0.3s ease;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .footer-links a:hover {
        color: var(--accent-light);
        padding-left: 5px;
      }

      .social-links {
        display: flex;
        gap: 15px;
      }

      .social-link {
        width: 45px;
        height: 45px;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent-light);
        font-size: 1.2rem;
        text-decoration: none;
        transition: 0.3s ease;
      }

      .social-link:hover {
        background: var(--accent-light);
        color: var(--bg-main);
        transform: translateY(-3px);
      }

      .footer-bottom {
        text-align: center;
        padding-top: 30px;
        border-top: 1px solid var(--border);
        color: var(--muted);
      }

      /* Responsive */
      @media (max-width: 992px) {
        .hero-container {
          grid-template-columns: 1fr;
          gap: 40px;
        }

        .hero-content h1 {
          font-size: 2.5rem;
        }

        .features-grid {
          grid-template-columns: 1fr;
          gap: 25px;
        }

        .footer-container {
          grid-template-columns: 1fr;
          gap: 40px;
        }
      }

      @media (max-width: 768px) {
        .nav-links {
          display: none;
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          background: var(--panel);
          flex-direction: column;
          padding: 20px;
          border-top: 1px solid var(--border);
        }

        .nav-links.show {
          display: flex;
        }

        .mobile-menu-toggle {
          display: block;
        }

        .hero-section {
          padding: 60px 20px;
        }

        .hero-content h1 {
          font-size: 2rem;
        }

        .hero-slider img {
          height: 300px;
        }

        .features-section h2,
        .cta-section h2 {
          font-size: 2rem;
        }

        .hero-buttons {
          flex-direction: column;
        }

        .btn-hero {
          width: 100%;
          justify-content: center;
        }
      }
    </style>
  </head>

  <body>
    <%- include('partials/navbar') %>

    <!-- Hero Section -->
    <section class="hero-section">
      <div class="hero-container">
        <div class="hero-content">
          <h1>Discover Your Next Adventure</h1>
          <p>
            Explore breathtaking campgrounds and create unforgettable memories
            in nature's embrace.
          </p>
          <div class="hero-buttons">
            <a href="/campgrounds" class="btn-hero btn-hero-primary"
              >Explore Campgrounds</a
            >
            <a href="/camps/new" class="btn-hero btn-hero-secondary"
              >Add Your Campground</a
            >
          </div>
        </div>
        <div class="hero-slider">
          <img
            src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80"
            alt="Campground 1"
            class="active"
          />
          <img
            src="https://images.unsplash.com/photo-1471115853179-bb1d604434e0?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80"
            alt="Campground 2"
          />
          <img
            src="https://images.unsplash.com/photo-1523987355523-c7b5b0dd90a7?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80"
            alt="Campground 3"
          />
          <button class="slider-arrow left" onclick="changeSlide(-1)">
            &lt;
          </button>
          <button class="slider-arrow right" onclick="changeSlide(1)">
            &gt;
          </button>
          <div class="slider-controls">
            <div class="slider-dot active" onclick="goToSlide(0)"></div>
            <div class="slider-dot" onclick="goToSlide(1)"></div>
            <div class="slider-dot" onclick="goToSlide(2)"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="features-section">
      <div class="features-container">
        <h2>Why Choose Vanvaas?</h2>
        <div class="features-grid">
          <div class="feature-card">
            <div class="feature-icon"><i class="bi bi-geo-alt"></i></div>
            <h3>Prime Locations</h3>
            <p>
              Discover campgrounds in stunning natural settings across the
              country.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon"><i class="bi bi-shield-check"></i></div>
            <h3>Safe & Secure</h3>
            <p>
              Your safety is our priority with verified locations and community
              reviews.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon"><i class="bi bi-tree"></i></div>
            <h3>Nature's Best</h3>
            <p>
              Immerse yourself in pristine wilderness and breathtaking
              landscapes.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
      <h2>Ready to Start Your Journey?</h2>
      <p>
        Join thousands of adventurers who have found their perfect camping spot
        with Vanvaas.
      </p>
      <a href="/register" class="btn-hero btn-hero-primary"
        >Get Started Today</a
      >
    </section>

    <%- include('partials/footer') %>

    <!-- YOUR SCRIPTS -->
    <script>
      function toggleMenu() {
        const navLinks = document.getElementById("navLinks");
        navLinks.classList.toggle("show");
      }

      let currentSlide = 0;
      const slides = document.querySelectorAll(".hero-slider img");
      const dots = document.querySelectorAll(".slider-dot");

      function showSlide(n) {
        slides.forEach((slide) => slide.classList.remove("active"));
        dots.forEach((dot) => dot.classList.remove("active"));
        currentSlide = (n + slides.length) % slides.length;
        slides[currentSlide].classList.add("active");
        dots[currentSlide].classList.add("active");
      }

      function changeSlide(direction) {
        showSlide(currentSlide + direction);
      }

      function goToSlide(n) {
        showSlide(n);
      }

      setInterval(() => {
        changeSlide(1);
      }, 5000);
    </script>
  </body>
</html>
